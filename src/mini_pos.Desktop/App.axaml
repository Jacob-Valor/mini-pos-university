<Application
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="mini_pos.App"
  xmlns:local="using:mini_pos"
  xmlns:conv="using:mini_pos.Converters"
  RequestedThemeVariant="Dark"
>
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
        <FontFamily
        x:Key="LaoFont"
      >avares://mini_pos/Assets/Fonts/NotoSansLaoLooped-Regular.ttf#Noto Sans Lao Looped, avares://mini_pos/Assets/Fonts/NotoSansLaoLooped-Bold.ttf#Noto Sans Lao Looped</FontFamily>

        <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Default">
                <SolidColorBrush x:Key="PrimaryColor">#03A9F4</SolidColorBrush>
                <SolidColorBrush
            x:Key="PrimaryDarkColor"
          >#0288D1</SolidColorBrush>
                <SolidColorBrush x:Key="AccentColor">#0288D1</SolidColorBrush>
                <SolidColorBrush x:Key="WarningColor">#F57C00</SolidColorBrush>
                <SolidColorBrush x:Key="ErrorColor">#C62828</SolidColorBrush>

                <SolidColorBrush
            x:Key="BackgroundColor"
          >#121212</SolidColorBrush>
                <SolidColorBrush x:Key="SurfaceColor">#1E1E1E</SolidColorBrush>
                <SolidColorBrush
            x:Key="SurfaceLightColor"
          >#2C2C2C</SolidColorBrush>
                <SolidColorBrush x:Key="TextColor">#FFFFFF</SolidColorBrush>
                <SolidColorBrush
            x:Key="TextMutedColor"
          >#B0BEC5</SolidColorBrush>
                <SolidColorBrush x:Key="BorderColor">#333333</SolidColorBrush>
                <SolidColorBrush
            x:Key="TopNavBackground"
          >#1E1E1E</SolidColorBrush>
                <SolidColorBrush
            x:Key="ThemeToggleBackgroundColor"
          >#33FFD54F</SolidColorBrush>
                <SolidColorBrush
            x:Key="ThemeToggleForegroundColor"
          >#FFFFD54F</SolidColorBrush>
                <SolidColorBrush
            x:Key="TableHeaderBackgroundColor"
          >#FFB74D</SolidColorBrush>
                <SolidColorBrush x:Key="RowHoverColor">#37474F</SolidColorBrush>
                <SolidColorBrush
            x:Key="RowSelectedColor"
          >#263238</SolidColorBrush>
            </ResourceDictionary>

            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="PrimaryColor">#03A9F4</SolidColorBrush>
                <SolidColorBrush
            x:Key="PrimaryDarkColor"
          >#0288D1</SolidColorBrush>
                <SolidColorBrush x:Key="AccentColor">#0288D1</SolidColorBrush>
                <SolidColorBrush x:Key="WarningColor">#F57C00</SolidColorBrush>
                <SolidColorBrush x:Key="ErrorColor">#C62828</SolidColorBrush>

                <SolidColorBrush
            x:Key="BackgroundColor"
          >#121212</SolidColorBrush>
                <SolidColorBrush x:Key="SurfaceColor">#1E1E1E</SolidColorBrush>
                <SolidColorBrush
            x:Key="SurfaceLightColor"
          >#2C2C2C</SolidColorBrush>
                <SolidColorBrush x:Key="TextColor">#FFFFFF</SolidColorBrush>
                <SolidColorBrush
            x:Key="TextMutedColor"
          >#B0BEC5</SolidColorBrush>
                <SolidColorBrush x:Key="BorderColor">#333333</SolidColorBrush>
                <SolidColorBrush
            x:Key="TopNavBackground"
          >#1E1E1E</SolidColorBrush>
                <SolidColorBrush
            x:Key="ThemeToggleBackgroundColor"
          >#33FFD54F</SolidColorBrush>
                <SolidColorBrush
            x:Key="ThemeToggleForegroundColor"
          >#FFFFD54F</SolidColorBrush>
                <SolidColorBrush
            x:Key="TableHeaderBackgroundColor"
          >#FFB74D</SolidColorBrush>
                <SolidColorBrush x:Key="RowHoverColor">#37474F</SolidColorBrush>
                <SolidColorBrush
            x:Key="RowSelectedColor"
          >#263238</SolidColorBrush>
            </ResourceDictionary>

            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="PrimaryColor">#03A9F4</SolidColorBrush>
                <SolidColorBrush
            x:Key="PrimaryDarkColor"
          >#0288D1</SolidColorBrush>
                <SolidColorBrush x:Key="AccentColor">#0288D1</SolidColorBrush>
                <SolidColorBrush x:Key="WarningColor">#F57C00</SolidColorBrush>
                <SolidColorBrush x:Key="ErrorColor">#C62828</SolidColorBrush>

                <SolidColorBrush
            x:Key="BackgroundColor"
          >#F5F5F5</SolidColorBrush>
                <SolidColorBrush x:Key="SurfaceColor">#FFFFFF</SolidColorBrush>
                <SolidColorBrush
            x:Key="SurfaceLightColor"
          >#EEEEEE</SolidColorBrush>
                <SolidColorBrush x:Key="TextColor">#212121</SolidColorBrush>
                <SolidColorBrush
            x:Key="TextMutedColor"
          >#757575</SolidColorBrush>
                <SolidColorBrush x:Key="BorderColor">#E0E0E0</SolidColorBrush>
                <SolidColorBrush
            x:Key="TopNavBackground"
          >#FAFAFA</SolidColorBrush>
                <SolidColorBrush
            x:Key="ThemeToggleBackgroundColor"
          >#3303A9F4</SolidColorBrush>
                <SolidColorBrush
            x:Key="ThemeToggleForegroundColor"
          >#FF03A9F4</SolidColorBrush>
                <SolidColorBrush
            x:Key="TableHeaderBackgroundColor"
          >#FF9800</SolidColorBrush>
                <SolidColorBrush x:Key="RowHoverColor">#E8E8E8</SolidColorBrush>
                <SolidColorBrush
            x:Key="RowSelectedColor"
          >#E3F2FD</SolidColorBrush>
            </ResourceDictionary>
        </ResourceDictionary.ThemeDictionaries>

        <!-- Shared UI Semantics -->
        <SolidColorBrush x:Key="ActionPrimaryColor">#03A9F4</SolidColorBrush>
        <SolidColorBrush
        x:Key="ActionPrimaryHoverColor"
      >#0288D1</SolidColorBrush>
        <SolidColorBrush x:Key="ActionWarningColor">#FBC02D</SolidColorBrush>
        <SolidColorBrush
        x:Key="ActionWarningHoverColor"
      >#F9A825</SolidColorBrush>
        <SolidColorBrush x:Key="ActionDangerColor">#C62828</SolidColorBrush>
        <SolidColorBrush
        x:Key="ActionDangerHoverColor"
      >#B71C1C</SolidColorBrush>
        <SolidColorBrush x:Key="ActionNeutralColor">#616161</SolidColorBrush>
        <SolidColorBrush
        x:Key="ActionNeutralHoverColor"
      >#757575</SolidColorBrush>

        <!-- Icons -->
        <StreamGeometry
        x:Key="IconHome"
      >M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z</StreamGeometry>
        <StreamGeometry
        x:Key="IconDatabase"
      >M12,3C7.58,3 4,4.79 4,7C4,9.21 7.58,11 12,11C16.42,11 20,9.21 20,7C20,4.79 16.42,3 12,3M4,9V12C4,14.21 7.58,16 12,16C16.42,16 20,14.21 20,12V9C20,11.21 16.42,13 12,13C7.58,13 4,11.21 4,9M4,14V17C4,19.21 7.58,21 12,21C16.42,21 20,19.21 20,17V14C20,16.21 16.42,18 12,18C7.58,18 4,16.21 4,14Z</StreamGeometry>
        <StreamGeometry
        x:Key="IconImport"
      >M14,12L10,8V11H2V13H10V16M20,18V6C20,4.89 19.1,4 18,4H6A2,2 0 0,0 4,6V9H6V6H18V18H6V15H4V18A2,2 0 0,0 6,20H18A2,2 0 0,0 20,18Z</StreamGeometry>
        <StreamGeometry
        x:Key="IconCustomer"
      >M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z</StreamGeometry>
        <StreamGeometry
        x:Key="IconProduct"
      >M17,18C15.89,18 15,18.89 15,20A2,2 0 0,0 17,22A2,2 0 0,0 19,20C19,18.89 18.1,18 17,18M1,2V4H3L6.6,11.59L5.25,14.04C5.09,14.32 5,14.65 5,15A2,2 0 0,0 7,17H19V15H7.42A0.25,0.25 0 0,1 7.17,14.75C7.17,14.7 7.18,14.66 7.2,14.63L8.1,13H15.55C16.3,13 16.96,12.59 17.3,11.97L21.16,4.96L19.42,4H19.41L18.31,6L15.55,11H8.53L8.4,10.73L6.16,6L5.21,4L4.27,2H1M7,18C5.89,18 5,18.89 5,20A2,2 0 0,0 7,22A2,2 0 0,0 9,20C9,18.89 8.1,18 7,18Z</StreamGeometry>
        <StreamGeometry
        x:Key="IconSearch"
      >M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z</StreamGeometry>
        <StreamGeometry
        x:Key="IconReport"
      >M13,9H18.5L13,3.5V9M6,2H14L20,8V20A2,2 0 0,1 18,22H6C4.89,22 4,21.1 4,20V4C4,2.89 4.89,2 6,2M15,18V16H6V18H15M18,14V12H6V14H18Z</StreamGeometry>
        <StreamGeometry
        x:Key="IconProfile"
      >M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z</StreamGeometry>
        <StreamGeometry
        x:Key="IconSettings"
      >M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.35 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.35 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,13L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.95C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z</StreamGeometry>
        <StreamGeometry
        x:Key="IconLogout"
      >M16.56,5.44L15.11,6.89C16.84,7.94 18,9.83 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12C6,9.83 7.16,7.94 8.88,6.88L7.44,5.44C5.36,6.88 4,9.28 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12C20,9.28 18.64,6.88 16.56,5.44M13,3H11V13H13</StreamGeometry>
        <StreamGeometry
        x:Key="IconSun"
      >M12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,2L14.39,5.42C13.65,5.15 12.84,5 12,5C11.16,5 10.35,5.15 9.61,5.42L12,2M3.34,7L7.5,6.65C6.9,7.16 6.36,7.78 5.94,8.5C5.5,9.24 5.25,10 5.11,10.79L3.34,7M3.36,17L5.12,13.23C5.26,14 5.53,14.78 5.95,15.5C6.37,16.24 6.91,16.86 7.5,17.37L3.36,17M20.65,7L18.88,10.79C18.74,10 18.47,9.23 18.05,8.5C17.63,7.78 17.1,7.15 16.5,6.64L20.65,7M20.64,17L16.5,17.36C17.09,16.85 17.62,16.22 18.04,15.5C18.46,14.77 18.73,14 18.87,13.21L20.64,17M12,22L9.59,18.56C10.33,18.83 11.14,19 12,19C12.82,19 13.63,18.83 14.37,18.56L12,22Z</StreamGeometry>
        <StreamGeometry
        x:Key="IconMoon"
      >M12,3A9,9 0 0,0 3,12A9,9 0 0,0 12,21A9,9 0 0,0 21,12C21,11.64 20.96,11.28 20.9,10.93C20.66,11.27 20.35,11.55 20,11.74V13.16C20,13.5 19.82,13.82 19.59,14C19.36,14.17 19.06,14.25 18.78,14.16C17.64,13.77 16.4,13.18 15.12,12.25C13.93,11.39 12.88,10.33 12,9.16C11.12,10.33 10.07,11.39 8.88,12.25C7.6,13.18 6.36,13.77 5.22,14.16C4.94,14.25 4.64,14.17 4.41,14C4.18,13.82 4,13.5 4,13.16V11.74C3.65,11.55 3.34,11.27 3.1,10.93C3.04,11.28 3,11.64 3,12A9,9 0 0,0 12,3Z</StreamGeometry>

        <conv:StringToBoolConverter x:Key="StringToBoolConverter" />
        <conv:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Global TextBox Style -->
        <Style Selector="TextBox.input">
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter
        Property="BorderBrush"
        Value="{StaticResource PrimaryColor}"
      />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextColor}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextColor}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter
        Property="SelectionBrush"
        Value="{StaticResource PrimaryColor}"
      />
        </Style>
        <Style
      Selector="TextBox.input:focus /template/ Border#PART_BorderElement"
    >
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter
        Property="BorderBrush"
        Value="{StaticResource PrimaryColor}"
      />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style
      Selector="TextBox.input:pointerover /template/ Border#PART_BorderElement"
    >
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter
        Property="BorderBrush"
        Value="{StaticResource PrimaryDarkColor}"
      />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- Global Button Style -->
        <Style Selector="Button.primary">
            <Setter
        Property="Background"
        Value="{StaticResource PrimaryColor}"
      />
            <Setter Property="Foreground" Value="{StaticResource TextColor}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="16,8" />
        </Style>
        <Style
      Selector="Button.primary:pointerover /template/ ContentPresenter"
    >
            <Setter
        Property="Background"
        Value="{StaticResource PrimaryDarkColor}"
      />
            <Setter Property="Foreground" Value="{StaticResource TextColor}" />
        </Style>

        <!-- Shared Action Buttons (CRUD) -->
        <Style Selector="Button.action">
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Button.action.primary">
            <Setter
        Property="Background"
        Value="{StaticResource ActionPrimaryColor}"
      />
        </Style>
        <Style
      Selector="Button.action.primary:pointerover /template/ ContentPresenter"
    >
            <Setter
        Property="Background"
        Value="{StaticResource ActionPrimaryHoverColor}"
      />
        </Style>

        <Style Selector="Button.action.warning">
            <Setter
        Property="Background"
        Value="{StaticResource ActionWarningColor}"
      />
            <Setter Property="Foreground" Value="Black" />
        </Style>
        <Style
      Selector="Button.action.warning:pointerover /template/ ContentPresenter"
    >
            <Setter
        Property="Background"
        Value="{StaticResource ActionWarningHoverColor}"
      />
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <Style Selector="Button.action.danger">
            <Setter
        Property="Background"
        Value="{StaticResource ActionDangerColor}"
      />
        </Style>
        <Style
      Selector="Button.action.danger:pointerover /template/ ContentPresenter"
    >
            <Setter
        Property="Background"
        Value="{StaticResource ActionDangerHoverColor}"
      />
        </Style>

        <Style Selector="Button.action.neutral">
            <Setter
        Property="Background"
        Value="{StaticResource ActionNeutralColor}"
      />
        </Style>
        <Style
      Selector="Button.action.neutral:pointerover /template/ ContentPresenter"
    >
            <Setter
        Property="Background"
        Value="{StaticResource ActionNeutralHoverColor}"
      />
        </Style>

        <!-- Consistent "table" ListBox rows -->
        <Style Selector="ListBox.table">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBox.table ListBoxItem">
            <Setter Property="Padding" Value="0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter
        Property="BorderBrush"
        Value="{StaticResource BorderColor}"
      />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox.table ListBoxItem:pointerover">
            <Setter
        Property="Background"
        Value="{StaticResource RowHoverColor}"
      />
        </Style>
        <Style Selector="ListBox.table ListBoxItem:selected">
            <Setter
        Property="Background"
        Value="{StaticResource RowSelectedColor}"
      />
        </Style>

        <Style Selector="Border.tableCell">
            <Setter
        Property="BorderBrush"
        Value="{DynamicResource BorderColor}"
      />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>
        <Style Selector="Border.tableCellLast">
            <Setter
        Property="BorderBrush"
        Value="{DynamicResource BorderColor}"
      />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <!-- Card Style -->
        <Style Selector="Border.card">
            <Setter
        Property="Background"
        Value="{DynamicResource SurfaceColor}"
      />
            <Setter
        Property="BorderBrush"
        Value="{DynamicResource BorderColor}"
      />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <!-- Section Header Style -->
        <Style Selector="TextBlock.sectionHeader">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <!-- Table Row Alternate Colors -->
        <Style Selector="ListBox.table ListBoxItem:nth-child(2n+1)">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox.table ListBoxItem:nth-child(2n)">
            <Setter
        Property="Background"
        Value="{DynamicResource SurfaceLightColor}"
      />
        </Style>
    </Application.Styles>
</Application>
